<Window x:Class="WpfProjekt.Window3"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfProjekt"
        mc:Ignorable="d"
        Title="Window3" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="259*"/>
            <ColumnDefinition Width="143*"/>
            <ColumnDefinition Width="392*"/>
        </Grid.ColumnDefinitions>
        <DataGrid x:Name="gridman" Grid.ColumnSpan="3" HorizontalAlignment="Left" Height="424" VerticalAlignment="Center" Width="800" d:ItemsSource="{d:SampleData ItemCount=5}" SelectionChanged="gridman_SelectionChanged" Grid.Column="1"/>

    </Grid>
</Window>
